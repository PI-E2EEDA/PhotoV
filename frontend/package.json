{
    "name": "frontend",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "run-p type-check \"build-only {@}\" --",
        "preview": "vite preview",
        "test:unit": "vitest",
        "build-only": "vite build",
        "type-check": "vue-tsc --build",
        "lint": "run-s lint:*",
        "lint:oxlint": "oxlint . --fix",
        "lint:eslint": "eslint . --fix --cache",
        "format": "prettier --write --experimental-cli src/",
        "apigen": "pnpx swagger-typescript-api generate --path https://api.photov.srd.rs/openapi.json -o src/api",
        "localapigen": "pnpx swagger-typescript-api generate --path http://localhost:8000/openapi.json -o src/api"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.2.2",
        "pinia": "^3.0.4",
        "tailwindcss": "^4.2.2",
        "vue": "^3.5.30",
        "vue-router": "^5.0.4"
    },
    "devDependencies": {
        "@tsconfig/node24": "^24.0.4",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^24.12.0",
        "@vitejs/plugin-vue": "^6.0.5",
        "@vitest/eslint-plugin": "^1.6.12",
        "@vue/eslint-config-typescript": "^14.7.0",
        "@vue/test-utils": "^2.4.6",
        "@vue/tsconfig": "^0.8.1",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-oxlint": "~1.50.0",
        "eslint-plugin-vue": "~10.8.0",
        "jiti": "^2.6.1",
        "jsdom": "^28.1.0",
        "npm-run-all2": "^8.0.4",
        "oxlint": "~1.50.0",
        "prettier": "3.8.1",
        "typescript": "~5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-vue-devtools": "^8.1.0",
        "vitest": "^4.1.0",
        "vue-tsc": "^3.2.6"
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    }
}
